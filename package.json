{
  "name": "node-service-console",
  "version": "1.0.0",
  "description": "Service management console for Node deployment, rollback, env and CI/CD settings",
  "main": "src/server.ts",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "cross-env PORT=3100 tsx --watch src/server.ts",
    "dev:web": "cd web && cross-env API_PORT=3100 npm run dev",
    "build:web": "cd web && npm run build",
    "typecheck": "tsc --noEmit",
    "reset-password": "tsx src/reset-password.ts"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "tsx": "^4.21.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "typescript": "^5.9.3"
  }
}
